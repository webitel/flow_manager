# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
ID=1

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LVL=debug
LOG_JSON=false
LOG_OTEL=false
LOG_FILE=
LOG_CONSOLE=false

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
SQL_DRIVER_NAME=postgres
DATA_SOURCE=postgres://postgres:postgres@postgres:5432/webitel?sslmode=disable&connect_timeout=10
SQL_DATA_SOURCE_REPLICAS=
SQL_MAX_IDLE_CONNS=5
SQL_MAX_OPEN_CONNS=5
SQL_CONN_MAX_LIFETIME_MILLISECONDS=300000
SQL_TRACE=false

# ---------------------------------------------------------------------------
# Message Queue (RabbitMQ / AMQP)
# ---------------------------------------------------------------------------
AMQP=amqp://admin:admin@rabbit:5672?heartbeat=10

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DATABASE=0

# ---------------------------------------------------------------------------
# gRPC server
# ---------------------------------------------------------------------------
GRPC_ADDR=localhost
GRPC_PORT=0

# ---------------------------------------------------------------------------
# WebHook server
# ---------------------------------------------------------------------------
WEB_ADDR=localhost:5689

# ---------------------------------------------------------------------------
# Service discovery (Consul)
# ---------------------------------------------------------------------------
CONSUL=consul:8500

# ---------------------------------------------------------------------------
# ESL (FreeSWITCH)
# ---------------------------------------------------------------------------
ESL_HOST=localhost
ELSE_PORT=10030

# ---------------------------------------------------------------------------
# TLS / mTLS
# ---------------------------------------------------------------------------
SERVICE_CONN_CLIENT_CA=
SERVICE_CONN_CLIENT_KEY=
SERVICE_CONN_CLIENT_CERT=

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
PRESIGNED_CERT=/opt/storage/key.pem
RECORD_SAMPLE=0
DEBUG_IMAP=false
CHAT_TEMPLATES_PATCH=./message_templates

# ---------------------------------------------------------------------------
# OpenTelemetry  (see .env.otel.example for full reference)
# ---------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_LOGS_EXPORTER=otlpgrpc
# OTEL_LOGRECORD_CODEC=otel
# OTEL_LOGRECORD_TIMESTAMP=2006-01-02 15:04:05.000000Z07:00
# OTEL_TRACES_EXPORTER=otlpgrpc
# OTEL_METRICS_EXPORT=
